<UserControl
    x:Class="DataBoard.Views.HistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
    xmlns:local="clr-namespace:DataBoard.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    DataContext="{Binding Source={StaticResource Locator}, Path=History}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <DataGrid
            Grid.Row="0"
            Height="500"
            AutoGenerateColumns="False"
            Background="White"
            BorderBrush="White"
            CanUserAddRows="False"
            ItemsSource="{Binding Historys}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Binding="{Binding Id}"
                    Header="编号"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Binding="{Binding Line.Name}"
                    Header="生产线"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Binding="{Binding SubLine.Name}"
                    Header="子线"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Binding="{Binding StopType.Name}"
                    Header="停止类型"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Binding="{Binding StartTime}"
                    Header="开始时间"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Binding="{Binding EndTime}"
                    Header="结束时间"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Binding="{Binding Minutes}"
                    Header="停机时长"
                    IsReadOnly="True" />


                <DataGridTextColumn
                    Binding="{Binding UserInfo.Name}"
                    Header="用户"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Binding="{Binding InsertDate}"
                    Header="插入时间"
                    IsReadOnly="True" />

                <DataGridTemplateColumn Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="5"
                                    Style="{StaticResource DataGrid_TextBlock}"
                                    Tag="{Binding}"
                                    Text="修改">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseUp">
                                            <i:InvokeCommandAction Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:HistoryView}, Path=DataContext.OpenEditHistoryWindowCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=TextBlock}, Path=Tag}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>

                                </TextBlock>

                                <TextBlock
                                    Grid.Column="1"
                                    Margin="5"
                                    Style="{StaticResource DataGrid_TextBlock}"
                                    Tag="{Binding}"
                                    Text="删除">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseUp">
                                            <i:InvokeCommandAction Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:HistoryView}, Path=DataContext.DeleteHistoryWindowCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=TextBlock}, Path=Tag}" />

                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBlock>
                            </Grid>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="15"
                Command="{Binding OpenAddHistoryWindowCommand}"
                Content="添加"
                FontSize="16"
                Style="{StaticResource LineView_ButtonStyle}"
                Tag="&#xf055;" />
        </StackPanel>
    </Grid>
</UserControl>
