<Window
    x:Class="DataBoard.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:DataBoard.Helpers"
    xmlns:local="clr-namespace:DataBoard.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LoginWindow"
    Width="800"
    Height="450"
    DataContext="{Binding Source={StaticResource Locator}, Path=LoginWindow}"
    WindowStyle="None"
    mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="500" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>


        <!--  左半部分  -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="4.5*" />
                <RowDefinition Height="5.5*" />
            </Grid.RowDefinitions>
            <Border Grid.RowSpan="2">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0 0" EndPoint="0 1">
                        <GradientStop Offset="0" Color="#83ABE9" />
                        <GradientStop Offset="0.9" Color="#C8B9D0" />
                        <GradientStop Offset="1" Color="#4E6A9C" />
                    </LinearGradientBrush>
                </Border.Background>

            </Border>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                <StackPanel.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Opacity="0.5"
                        ShadowDepth="2"
                        Color="Black" />
                </StackPanel.Effect>
                <TextBlock
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    FontSize="23"
                    Foreground="White"
                    Text="Wellcome" />
                <TextBlock
                    FontSize="25"
                    Foreground="White"
                    Text="后台管理系统" />
            </StackPanel>
        </Grid>


        <!--  右半部分  -->
        <Grid Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock
                    Margin="15"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    FontFamily="/Fonts/#FontAwesome"
                    FontSize="22"
                    MouseUp="TextBlock_MouseUp"
                    Style="{StaticResource logintextblock}"
                    Text="&#xf2d3;"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
                <TextBox
                    Grid.Row="1"
                    Width="270"
                    Height="35"
                    VerticalAlignment="Bottom"
                    helpers:TextBoxHelper.Icon="👤"
                    helpers:TextBoxHelper.Placeholder="请输入用户名"
                    FontSize="16"
                    Style="{StaticResource UnderlineTextBoxStyle}"
                    Text="{Binding AppData.CurrentUser.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />

                <TextBox
                    Grid.Row="2"
                    Width="270"
                    Height="35"
                    helpers:TextBoxHelper.Icon="🔒︎"
                    helpers:TextBoxHelper.Placeholder="请输入密码"
                    FontSize="16"
                    Style="{StaticResource UnderlineTextBoxStyle}"
                    Text="{Binding AppData.CurrentUser.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
                <Button
                    Grid.Row="3"
                    VerticalAlignment="Top"
                    Command="{Binding CheckUserCommand2}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="登录"
                    Style="{StaticResource LoginButtonStyle}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />

            </Grid>

        </Grid>
    </Grid>
</Window>
