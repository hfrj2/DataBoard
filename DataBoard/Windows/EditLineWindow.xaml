<Window
    x:Class="DataBoard.Windows.EditLineWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DataBoard.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="修改生产线"
    Width="400"
    Height="200"
    DataContext="{Binding Source={StaticResource Locator}, Path=EditLineWindow}"
    mc:Ignorable="d">
    <Grid>
    <Grid Margin="30 50 30 50">

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
            <TextBlock Height="35"  Text="{Binding Line.Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"    />
            <Button Grid.Column="1" Command="{Binding AddLineCommand}" Content="添加" Tag="&#xf055;"  Margin="15" Style="{StaticResource LineView_ButtonStyle}" FontSize="16"   />
        </Grid>
    </Grid>

</Window>
