<Window
    x:Class="DataBoard.Windows.AddHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:DataBoard.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DataBoard.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="添加历史记录"
    Width="520"
    Height="300"
    Background="#282828"
    DataContext="{Binding Source={StaticResource Locator}, Path=AddHistoryWindow}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="200" />
    </WindowChrome.WindowChrome>
    <Border BorderBrush="White" BorderThickness="1">
        <Grid>
            <TextBlock
                MouseUp="TextBlock_MouseUp"
                Style="{StaticResource AddLine_TextBlockIcon}"
                Text="&#xf011;"
                WindowChrome.IsHitTestVisibleInChrome="True" />
            <Grid Margin="20,20,30,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />

                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>


                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="White"
                    Text="生产线:   " />
                <ComboBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding Lines}"
                    SelectedItem="{Binding History.Line}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="White"
                    Text="子   线:   " />
                <ComboBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding SubLines}"
                    SelectedItem="{Binding History.SubLine}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="White"
                    Text="停机类型:   " />
                <ComboBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="5"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding StopTypes}"
                    SelectedItem="{Binding History.StopType}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="White"
                    Text="开始时间:   " />


                <controls:DateTimeControl
                    Grid.Row="3"
                    Grid.Column="1"
                    MaxHeight="25"
                    WindowChrome.IsHitTestVisibleInChrome="True" 
                    Now="{Binding History.StartTime}"/>
                <controls:DateTimeControl
                    Grid.Row="4"
                    Grid.Column="1"
                    MaxHeight="25"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Now="{Binding StopTypes}"/>


                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="White"
                    Text="结束时间:   " />




                <!--    -->
                <Button
                    Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Command="{Binding AddHistoryCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:AddHistoryWindow}}"
                    Content="添加"
                    FontSize="14"
                    Style="{StaticResource AddUserInfoView_ButtonStyle}"
                    Tag="&#xf055;"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
            </Grid>
        </Grid>
    </Border>
</Window>
