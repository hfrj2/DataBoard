<Window
    x:Class="DataBoard.Windows.AddUserInfoWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DataBoard.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="添加生产线"
    Width="400"
    Height="200"
    Background="#282828"
    DataContext="{Binding Source={StaticResource Locator}, Path=AddUserInfoWindow}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="200" />
    </WindowChrome.WindowChrome>
    <Border BorderBrush="White" BorderThickness="1">
        <Grid>
            <TextBlock
                MouseUp="TextBlock_MouseUp"
                Style="{StaticResource AddLine_TextBlockIcon}"
                Text="&#xf011;"
                WindowChrome.IsHitTestVisibleInChrome="True" />
            <Grid Margin="30">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />

                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>


                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="16"
                    Foreground="White"
                    Text="用户名:   " />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Height="35"
                    Margin="5"
                    MaxLength="32"
                    Text="{Binding CurrentUser.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    FontSize="16"
                    Foreground="White"
                    Text="密   码:   " />
                <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Height="35"
                    Margin="5"
                    MaxLength="32"
                    Text="{Binding CurrentUser.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    FontSize="16"
                    Foreground="White"
                    Text="角   色:   " />
                <ComboBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="35"
                    Margin="5"
                    DisplayMemberPath="Name"
                    SelectedValuePath="Id"
                    ItemsSource="{Binding AppData.RoleModels}"
                    SelectedItem="{Binding CurrentUser.RoleModel}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />



                <!--    -->
                <Button
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Command="{Binding AddUserInfoCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:AddUserInfoWindow}}"
                    Content="添加"
                    FontSize="14"
                    Style="{StaticResource AddUserInfoView_ButtonStyle}"
                    Tag="&#xf055;"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
            </Grid>
        </Grid>
    </Border>
</Window>
