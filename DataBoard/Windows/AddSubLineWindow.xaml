<Window
    x:Class="DataBoard.Windows.AddSubLineWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DataBoard.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="添加子线"
    Width="400"
    Height="200"
    Background="#282828"
    DataContext="{Binding Source={StaticResource Locator}, Path=AddSubLineWindow}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="200" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="White" BorderThickness="1">
        <Grid>
            <TextBlock
                MouseUp="TextBlock_MouseUp"
                Style="{StaticResource AddLine_TextBlockIcon}"
                Text="&#xf011;"
                WindowChrome.IsHitTestVisibleInChrome="True" />
            <Grid Margin="30,50,30,50">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Height="35"
                    MaxLength="32"
                    Text="{Binding SubLine.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
                <Button
                    Grid.Column="1"
                    Margin="15"
                    Command="{Binding AddSubLineCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:AddSubLineWindow}}"
                    Content="添加"
                    FontSize="16"
                    Style="{StaticResource LineView_ButtonStyle}"
                    Tag="&#xf055;"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
            </Grid>
        </Grid>
    </Border>
</Window>